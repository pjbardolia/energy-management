      "slave_id":              1,
      "vfd_model":             "INVT_CHF100A",
      "component_instance_id": 7
    },
    {
      "name":                  "Jet 02",
      "slave_id":              2,
      "vfd_model":             "INVT_CHF100A",
      "component_instance_id": 8
    }
  ]
